# Exemplo de arquivo de ambiente para o projeto
# Copie este arquivo para .env e preencha os valores.

# Token GitHub com escopo public_repo ou repo
GITHUB_TOKEN=

# Repositório a ser minerado (owner/name)
REPO=fastapi/typer

# Modo offline: true para usar o arquivo sample e não chamar a API
OFFLINE=false

# Arquivo de amostra para modo offline
SAMPLE=data/sample_typer_interactions.json

# Pasta de saída dos arquivos gerados
OUTPUT=output

# Limites de extração (ajuste conforme quiser)
# Use 0 para minerar tudo
MAX_ISSUES=0
MAX_PULLS=0

# Requisições paralelas à API (padrão: 8)
WORKERS=8

# Reutilizar cache salvo em output/interactions_cache.json
USE_CACHE=false
